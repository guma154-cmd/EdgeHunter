# ============================================================
# EdgeHunter — Configurações de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores

# --- Servidor Flask ---
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=mude-esta-chave-para-producao

# --- Banco de Dados ---
DATABASE_URL=sqlite:///database/edgehunter.db

# --- The Odds API ---
# Cadastre em: https://the-odds-api.com
ODDS_API_KEY=sua_chave_aqui

# --- Football-Data.org ---
# Cadastre em: https://www.football-data.org
FOOTBALL_DATA_API_KEY=sua_chave_aqui

# --- Telegram Bot ---
# Crie via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# --- Configurações do Motor ---
MIN_EDGE_PCT=3.0          # Edge mínimo para gerar alerta (%)
PAPER_TRADING_STAKE=10.0  # Stake padrão no paper trading (unidades)
ROLLING_WINDOW_DAYS=30    # Janela para Sharpe Ratio
DRIFT_THRESHOLD=0.05      # Threshold para concept drift
AB_TEST_MIN_BETS=50       # Mínimo de apostas para promover modelo A/B

# --- Casas de Apostas Target ---
SHARP_BOOK=pinnacle
SOFT_BOOKS=bet365,betano,superbet

# --- Scheduler ---
ODDS_FETCH_INTERVAL_MINUTES=15
RESULT_CHECK_INTERVAL_MINUTES=30
RETRAIN_HOUR=4            # Hora do retraining diário (UTC)
